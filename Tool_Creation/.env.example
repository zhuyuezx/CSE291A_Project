# LLM API Configuration
# Copy this file to .env and fill in your actual API keys.
# .env is gitignored and will NOT be committed.

# Comma-separated list of API keys (for round-robin distribution)
API_KEYS=sk-your-key-1,sk-your-key-2,sk-your-key-3

# Base URL for the OpenAI-compatible API
OPENAI_BASE_URL=https://tritonai-api.ucsd.edu

# Model name
MODEL_NAME=api-gpt-oss-120b

# Debug mode: set to 1 to log all LLM prompts and responses to LLM/debug_logs/
# Each optimizer session gets its own timestamped folder.
LLM_DEBUG=0

\newlabel{fig:dqncomp}{{5a}{8}{\textbf {TextWorld generalization}: our method shows near-perfect return scores and efficient execution across all game complexities, while DQN hits a complexity wall around 11 rooms, beyond which no generalization is possible}{figure.caption.7}{}}
\newlabel{sub@fig:dqncomp}{{a}{8}{\textbf {TextWorld generalization}: our method shows near-perfect return scores and efficient execution across all game complexities, while DQN hits a complexity wall around 11 rooms, beyond which no generalization is possible}{figure.caption.7}{}}
\newlabel{fig:zorkcomp}{{5b}{8}{\textbf {Zork subset scaling}: the llm-optimized MCTS algorithm provides a $\sim 20\%$ performance lift in solvable environments (8--10 rooms), but is limited by the complexity wall starting at 12 rooms where state-space dependencies peak without more steps}{figure.caption.7}{}}
\newlabel{sub@fig:zorkcomp}{{b}{8}{\textbf {Zork subset scaling}: the llm-optimized MCTS algorithm provides a $\sim 20\%$ performance lift in solvable environments (8--10 rooms), but is limited by the complexity wall starting at 12 rooms where state-space dependencies peak without more steps}{figure.caption.7}{}}
